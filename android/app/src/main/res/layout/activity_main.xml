<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingTop="28dp"
        android:paddingEnd="20dp"
        android:paddingBottom="28dp">

        <TextView
            android:id="@+id/titleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/app_title"
            android:textColor="@color/text_primary"
            android:textSize="28sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/subtitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="@string/app_subtitle"
            android:textColor="@color/text_secondary"
            android:textSize="15sp" />

        <TextView
            android:id="@+id/preferenceLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/preference_label"
            android:textColor="@color/text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/preferenceSpinner"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:background="@drawable/spinner_background"
            android:paddingStart="12dp"
            android:paddingEnd="12dp" />

        <TextView
            android:id="@+id/connectionMessage"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/message_background"
            android:padding="12dp"
            android:text="@string/loading_message"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/room1Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/room1Name"
                    style="@style/RoomNameText"
                    android:text="Aula 1" />

                <TextView
                    android:id="@+id/room1Temperature"
                    style="@style/RoomMetricText"
                    android:text="Temperatura: N/D" />

                <ProgressBar
                    android:id="@+id/room1TemperatureBar"
                    style="@style/RoomChartBar"
                    android:max="40"
                    android:progress="0"
                    android:progressTint="@color/chart_temperature" />

                <TextView
                    android:id="@+id/room1Humidity"
                    style="@style/RoomMetricText"
                    android:text="Umidita: N/D" />

                <ProgressBar
                    android:id="@+id/room1HumidityBar"
                    style="@style/RoomChartBar"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/chart_humidity" />

                <TextView
                    android:id="@+id/room1Noise"
                    style="@style/RoomMetricText"
                    android:text="Rumore: N/D" />

                <ProgressBar
                    android:id="@+id/room1NoiseBar"
                    style="@style/RoomChartBar"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/chart_noise" />

                <TextView
                    android:id="@+id/room1Presence"
                    style="@style/RoomMetricText"
                    android:text="Presenza: N/D" />

                <TextView
                    android:id="@+id/room1LastUpdate"
                    style="@style/RoomMetricText"
                    android:text="Ultimo aggiornamento: N/D" />

                <TextView
                    android:id="@+id/room1Score"
                    style="@style/RoomScoreText"
                    android:text="Score: N/D" />

                <TextView
                    android:id="@+id/room1Status"
                    style="@style/RoomStatusText"
                    android:text="Stato: dati non disponibili" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/room2Card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="18dp">

                <TextView
                    android:id="@+id/room2Name"
                    style="@style/RoomNameText"
                    android:text="Aula 2" />

                <TextView
                    android:id="@+id/room2Temperature"
                    style="@style/RoomMetricText"
                    android:text="Temperatura: N/D" />

                <ProgressBar
                    android:id="@+id/room2TemperatureBar"
                    style="@style/RoomChartBar"
                    android:max="40"
                    android:progress="0"
                    android:progressTint="@color/chart_temperature" />

                <TextView
                    android:id="@+id/room2Humidity"
                    style="@style/RoomMetricText"
                    android:text="Umidita: N/D" />

                <ProgressBar
                    android:id="@+id/room2HumidityBar"
                    style="@style/RoomChartBar"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/chart_humidity" />

                <TextView
                    android:id="@+id/room2Noise"
                    style="@style/RoomMetricText"
                    android:text="Rumore: N/D" />

                <ProgressBar
                    android:id="@+id/room2NoiseBar"
                    style="@style/RoomChartBar"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/chart_noise" />

                <TextView
                    android:id="@+id/room2Presence"
                    style="@style/RoomMetricText"
                    android:text="Presenza: N/D" />

                <TextView
                    android:id="@+id/room2LastUpdate"
                    style="@style/RoomMetricText"
                    android:text="Ultimo aggiornamento: N/D" />

                <TextView
                    android:id="@+id/room2Score"
                    style="@style/RoomScoreText"
                    android:text="Score: N/D" />

                <TextView
                    android:id="@+id/room2Status"
                    style="@style/RoomStatusText"
                    android:text="Stato: dati non disponibili" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/recommendedRoomText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:background="@drawable/recommendation_background"
            android:padding="16dp"
            android:text="Aula consigliata: dati non disponibili"
            android:textColor="@color/text_primary"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</ScrollView>
